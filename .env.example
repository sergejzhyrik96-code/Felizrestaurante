# Server-side (Vercel project env / .env for vercel dev)
# Do not commit real values. Set these in Vercel Dashboard → Project → Settings → Environment Variables.

# Supabase (use service role for API; anon key stays in client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Bot (admin notifications for new reservations)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (confirmation emails)
RESEND_API_KEY=
# Optional: from address (default: onboarding@resend.dev)
# RESEND_FROM=FELIZ Valencia <reservas@yourdomain.com>

# Admin panel password
ADMIN_PASSWORD=

# Optional: site URL for cancel links in emails (default: VERCEL_URL or felizrestaurante1.vercel.app)
# SITE_URL=https://felizrestaurante1.vercel.app
